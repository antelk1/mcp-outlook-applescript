{
  "name": "mcp-outlook-applescript",
  "version": "1.2.0",
  "description": "MCP server for Microsoft Outlook on Mac. Access mail, calendar, contacts, tasks, and notes via AppleScript.",
  "type": "module",
  "bin": {
    "mcp-outlook-applescript": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm test && npm run typecheck",
    "start": "node dist/index.js",
    "test": "vitest run"
  },
  "keywords": [
    "mcp",
    "outlook",
    "macos",
    "email",
    "calendar",
    "contacts",
    "tasks",
    "model-context-protocol",
    "applescript"
  ],
  "author": "Hasan Imam <hasan.imam.w@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hasan-imam/mcp-outlook-applescript.git"
  },
  "homepage": "https://github.com/hasan-imam/mcp-outlook-applescript#readme",
  "bugs": {
    "url": "https://github.com/hasan-imam/mcp-outlook-applescript/issues"
  },
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  }
}
